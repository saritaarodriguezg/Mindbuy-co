        <div class="form-actions">
          <button class="btn btn-primary btn-full btn-lg" id="btn-register">Crear mi cuenta</button>
        </div>
      </div>
      <p class="form-footer">¿Ya tienes cuenta? <button onclick="showView('login')">Iniciar sesión</button></p>
